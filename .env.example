# Flask 基礎設定
SECRET_KEY=change-this-to-a-random-string

# 資料庫連線（預設使用 SQLite，存於 data/config_manager.db）
DATABASE_URL=sqlite:///data/config_manager.db

# Fernet 加密金鑰（用於加密 DB 中的 SSH / 設備密碼）
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CRYPTO_KEY=

# 顯示時區（預設 Asia/Taipei）
DISPLAY_TZ=Asia/Taipei

# 備份檔案儲存根目錄（預設專案內 backups/）
# BACKUP_BASE_PATH=/var/lib/config-manager/backups
